    <Folder Include="dm\Stored Procedures\Update" />
    <Folder Include="dm\Tables" />
    <Folder Include="Scripts" />
    <Folder Include="Scripts\Seeds" />
    <Folder Include="Security" />
    <Folder Include="Security\Schemas" />
    <Folder Include="SchemaComparison" />
  </ItemGroup>
  <ItemGroup>
